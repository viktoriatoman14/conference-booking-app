@model IEnumerable<ConferenceBookingApp.Models.Professors>

@{
    ViewData["Title"] = "Lista Profesorów";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Nauczyciele akademiccy</h4>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn btn-success btn-sm">Dodaj nowego</a>
            }
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Tytuł naukowy</th>
                            <th>Imię</th>
                            <th>Nazwisko</th>
                            <th>Adres E-mail</th>
                            @if (User.IsInRole("Admin"))
                            {
                                <th>Akcje</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.AcademicTitle</td>
                                <td>@item.FirstName</td>
                                <td>@item.LastName</td>
                                <td>
                                    @if (string.IsNullOrEmpty(item.Email))
                                    {
                                        <span class="text-muted">Brak adresu</span>
                                    }
                                    else
                                    {
                                        <strong>@item.Email</strong>
                                    }
                                </td>
                                @if (User.IsInRole("Admin"))
                                {
                                    <td>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">Edytuj</a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm">Szczegóły</a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">Usuń</a>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>