@model IEnumerable<ConferenceBookingApp.Models.PageContent>

@{
    ViewData["Title"] = "Zarządzanie Treścią";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Zarządzanie Treścią Strony</h4>
        </div>
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Klucz</th>
                        <th>Wartość</th>
                        <th>Akcje</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Key</td>
                            <td>@item.Value</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Edytuj</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <p class="text-muted small">Wskazówka: Jeśli tabela jest pusta, upewnij się, że baza danych została zainicjowana danymi początkowymi.</p>
        </div>
    </div>
</div>
