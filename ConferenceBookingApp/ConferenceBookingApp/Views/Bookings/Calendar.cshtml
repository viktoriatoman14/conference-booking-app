@{
    ViewData["Title"] = "Kalendarz Rezerwacji";
}

<div class="container mt-4">
    <div class="card shadow rounded-4 overflow-hidden border-0">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3 px-4">
            <h4 class="mb-0 fw-semibold">📅 Harmonogram Rezerwacji Sal</h4>
            @if (User.IsInRole("Admin, User"))
            {
                <a asp-action="Create" class="btn btn-success btn-sm rounded-3 px-3 fw-medium shadow-sm">Dodaj rezerwację</a>
            }
        </div>
        <div class="card-body p-4 bg-white">
            <div id="calendar"></div>
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/locales/pl.global.min.js"></script>

<style>
    .fc {
        background-color: rgba(255, 255, 255, 0.9) !important;
        backdrop-filter: blur(10px);
        border-radius: 12px;
        padding: 15px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);

        max-height: 650px !important;
    }

    .fc-scroller {
        overflow-y: auto !important;
    }

    .fc-event {
        background-color: rgba(13, 110, 253, 0.12) !important;
        border: 1px solid #0d6efd !important;
        border-left-width: 4px !important;
        border-radius: 6px !important;
        padding: 3px 5px !important;
        transition: transform 0.2s;
        cursor: pointer;
    }

        .fc-event:hover {
            transform: scale(1.02);
        }

    .fc-event-main, .fc-event-title, .fc-event-time {
        color: #1e293b !important;
        font-weight: 600 !important;
        font-size: 0.85rem !important;
        white-space: normal !important;
    }

    .fc-col-header-cell {
        background-color: #212529 !important; 
        padding: 8px 0 !important;
    }

    .fc-col-header-cell-cushion {
        color: #ffffff !important;
        text-decoration: none !important;
        font-weight: 600 !important;
    }

    .fc-sidebar-title,
    .fc-col-header-cell.fc-day-today {
        background-color: #0d6efd !important; 
    }

        .fc-col-header-cell.fc-day-today .fc-col-header-cell-cushion {
            color: #ffffff !important; 
        }

    .fc-day-today {
        background-color: rgba(13, 110, 253, 0.03) !important;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        var calendarEl = document.getElementById('calendar');

        var calendar = new FullCalendar.Calendar(calendarEl, {
            initialView: 'timeGridWeek',
            locale: 'pl',
            slotMinTime: '08:00:00',
            slotMaxTime: '23:00:00',
            allDaySlot: false,
            slotDuration: '01:00:00', 
            slotLabelFormat: {
                hour: 'numeric',
                minute: '2-digit',
                hour12: false
            },

            headerToolbar: {
                left: 'prev,next today',
                center: 'title',
                right: 'dayGridMonth,timeGridWeek,timeGridDay'
            },
            events: '/Bookings/GetCalendarData',
            eventClick: function(info) {
                window.location.href = '/Bookings/Details/' + info.event.id;
            },

            windowResize: function(view) {
        if (window.innerWidth < 768) {
            calendar.changeView('listWeek'); // Na telefonie jako lista
        } else {
            calendar.changeView('timeGridWeek'); // Na komputerze 
        }
    },
        });

        calendar.render();
    });
</script>