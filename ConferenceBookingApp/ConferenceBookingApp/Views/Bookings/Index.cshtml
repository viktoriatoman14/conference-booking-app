@model IEnumerable<ConferenceBookingApp.Models.Bookings>

@{
    ViewData["Title"] = "Lista Rezerwacji";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Lista Rezerwacji Sal</h4>

            @if (User.Identity.IsAuthenticated)
            {
                <a asp-action="Create" class="btn btn-success btn-sm">Zarezerwuj salę</a>
            }
        </div>
        <div class="card-body">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Data rozpoczęcia</th>
                        <th>Data zakończenia</th>
                        <th>Cel spotkania</th>
                        <th>Numer sali</th>
                        <th>Profesor</th>
                        @if (User.IsInRole("Admin"))
                        {
                            <th>Akcje</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.StartDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@item.EndDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@item.MeetingPurpose</td>
                            <td>
                                <span class="badge bg-secondary">Sala @item.ConferenceRoom?.Nnumber</span>
                            </td>
                            <td>
                                <strong>@item.Professor?.FullName</strong>
                            </td>
                            @if (User.IsInRole("Admin"))
                            {
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">Edytuj</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm">Szczegóły</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">Usuń</a>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>