<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ConferenceBookingApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ConferenceBookingApp.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            background-image: url('https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=1964&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
            background-attachment: fixed; /* Tło stoi w miejscu podczas przewijania */
            min-height: 100vh;
        }

        .card {
            background-color: rgba(255, 255, 255, 0.85) !important;
            backdrop-filter: blur(5px); 
        }

        .navbar {
            background-color: rgba(255, 255, 255, 0.9) !important;
        }
    </style>
</head>
<body class="bg-light">
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm py-3 mb-4">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary" asp-area="" asp-controller="Home" asp-action="Index">ConferenceBookingApp</a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-3 gap-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-medium rounded-2 px-3" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1 text-secondary"></i> Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-medium rounded-2 px-3" asp-area="" asp-controller="Home" asp-action="Privacy">
                                <i class="bi bi-shield-lock me-1 text-secondary"></i> Privacy
                            </a>
                        </li>
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-medium rounded-2 px-3" asp-controller="Account" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right me-1 text-danger"></i> Wyloguj (@User.Identity.Name)
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-medium rounded-2 px-3" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1 text-primary"></i> Zaloguj się
                                </a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-medium rounded-2 px-3" asp-controller="Bookings" asp-action="Calendar">
                                <i class="bi bi-calendar3 me-1 text-secondary"></i> Kalendarz
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-medium rounded-2 px-3" asp-controller="ConferenceRooms" asp-action="AvailableRooms">
                                <i class="bi bi-search me-1 text-secondary"></i> Wolne sale
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-medium rounded-2 px-3" asp-area="" asp-controller="Professors" asp-action="Index">
                                <i class="bi bi-person-workspace me-1 text-secondary"></i> Nauczyciele Akademiccy
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-medium rounded-2 px-3" asp-area="" asp-controller="ConferenceRooms" asp-action="Index">
                                <i class="bi bi-building me-1 text-secondary"></i> Sale Konferencyjne
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-medium rounded-2 px-3" asp-area="" asp-controller="Bookings" asp-action="Index">
                                <i class="bi bi-bookmark-check me-1 text-secondary"></i> Rezerwacje
                            </a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-medium rounded-2 px-3" asp-area="" asp-controller="PageContent" asp-action="Index">
                                    <i class="bi bi-pencil-square me-1 text-primary"></i> Edytuj Treść
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - ConferenceBookingApp - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
