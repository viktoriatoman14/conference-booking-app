@model IEnumerable<ConferenceBookingApp.Models.ConferenceRooms>

@{
    ViewData["Title"] = "Sale Konferencyjne";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Sale konferencyjne</h4>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn btn-success btn-sm">Dodaj nową salę</a>
            }
        </div>
        <div class="card-body">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Numer sali</th>
                        <th>Piętro</th>
                        <th>Dostępność</th>
                        @if (User.IsInRole("Admin"))
                        {
                            <th>Akcje</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.Nnumber</strong></td>
                            <td>@item.Floor</td>
                            <td>
                                @if (item.IsAvailable)
                                {
                                    <span class="badge bg-success">Dostępna</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Wyłączona z użytku</span>
                                }
                            </td>
                            @if (User.IsInRole("Admin"))
                            {
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">Edytuj</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm">Szczegóły</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">Usuń</a>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>